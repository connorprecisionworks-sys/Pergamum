# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL (for OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI — used by the /build prompt builder for "Generate from goal" and
# "Improve this block". The whole feature still works without a key, just
# without the AI assist.
OPENAI_API_KEY=sk-...

# Builder access gate. Set this to gate /build behind a shared code. Users
# enter the code once and get a 30-day cookie. Leave empty to disable the
# gate entirely (everyone signed in can use the builder).
BUILD_ACCESS_CODE=
